# ===============================
# DVC / Artifacts (IMPORTANT)
# ===============================

# Ignore everything under artifacts by default
artifacts/**

# Re-allow directory traversal (CRITICAL)
!artifacts/
!artifacts/**/

# Allow only DVC-tracked data and metadata
!artifacts/data/**
!artifacts/**/*.dvc

# ===============================
# DVC config
# ===============================
!.dvc/
!.dvc/config
!.dvcignore

# ===============================
# ML artifacts & generated outputs
# ===============================
logs/
synthetic_generation/
Clinical_Readmission.egg-info/

# ===============================
# Virtual environments
# ===============================
venv/
.venv/
env/
ENV/

# ===============================
# Python
# ===============================
__pycache__/
*.py[cod]

# ===============================
# Logs & temp
# ===============================
*.log
tmp/
temp/

# ===============================
# Non-source src directory
# ===============================
src/

# ===============================
# Config
# ===============================
config/

# ===============================
# Python packaging
# ===============================
*.egg-info/
build/
dist/
.eggs/

# ===============================
