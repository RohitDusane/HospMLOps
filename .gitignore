# ML artifacts & generated outputs
logs/
synthetic_generation/
Clinical_Readmission.egg-info/

# Ignore all artifacts by default
artifacts/**

# But allow DVC-tracked data and metadata
!artifacts/**/*.dvc
!artifacts/data/

# Track DVC project config
!.dvc/config
!.dvcignore

# Virtual environments
venv/
.venv/
env/
ENV/

# Python bytecode
__pycache__/
*.py[cod]

# Logs, temp, and reports
*.log
tmp/
temp/

# Non-source src directory
src/

# Configuration generated per environment
config/

# Package metadata
Clinical_Readmission.egg-info/
*.egg-info/

# Generated reports / UI artifacts
project_code.html
tabs.html

# Standalone scripts
demo.py
test.py

# Ignore experimental / comparison components
readmit/components/*.py

# Standard Python ignores
build/
dist/
.eggs/
pip-wheel-metadata/
.pytest_cache/
.tox/
.nox/
.coverage*
htmlcov/
coverage.xml
nosetests.xml
.mypy_cache/
.pyre/
.pytype/
.ipynb_checkpoints/

# ML/Data-specific ignores
*.pkl
*.joblib
*.h5
*.onnx
*.pt
*.ckpt
mlruns/
wandb/
tensorboard/
tb_logs/
report.md
.dvc/tmp/

# Secrets & environment variables
.env
.env.* 
*.key
*.pem
*.crt
secrets.yml
secrets.yaml

# OS & editor files
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*.swo
*.tmp
*.bak

# Archives
*.zip
*.tar
*.tar.gz
*.rar
